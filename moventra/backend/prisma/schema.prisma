generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  city         String?
  createdAt    DateTime @default(now())

  //  Account status
  isActive     Boolean  @default(true)
  deactivatedAt DateTime?
  deactivationScheduledAt DateTime?

  //  Email verification fields
  isEmailVerified         Boolean   @default(false)
  emailVerificationToken  String?   @unique
  emailVerificationSentAt DateTime?

  //  Onboarding fields
  onboardingCompleted Boolean   @default(false)
  onboardingPurpose   String?
  birthDate           DateTime?
  gender              String?
  planType            String?   @default("free")

  //  Profile / settings fields
  bio           String?
  showGroups    Boolean  @default(true)
  showInterests Boolean  @default(true)

  // OAuth + profil fields
  googleId   String?  @unique
  appleId    String?  @unique
  avatarUrl  String?

  hobbies        UserHobby[]
  eventsCreated  Event[]            @relation("UserEventsCreated")
  participations EventParticipant[]
  favorites      EventFavorite[]
  comments       EventComment[]
  messages       EventMessage[]
  avatar         UserAvatar?
  avatarItems    UserAvatarItem[]

  // 🔍 ML logging: kullanıcıya ait view / click kayıtları
  eventViews     EventView[]
  eventClicks    EventClick[]

  // ✅ GDPR talepleri
  gdprRequests   GdprRequest[]
}

model GdprRequest {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  message   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserAvatar {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique

  gender     String?
  bodyType   String?

  hairColor  String   @default("#facc15")
  shirtColor String   @default("#3b82f6")
  pantsColor String   @default("#111827")
  skinColor  String   @default("#f3c9a8")

  hasHat     Boolean  @default(false)
  hatColor   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
}

model AvatarItem {
  id         Int      @id @default(autoincrement())
  name       String
  slot       String   // "hair" | "top" | "bottom" | "shoes" | "accessory"
  modelUrl   String?
  textureUrl String?

  isDefault  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ownedBy    UserAvatarItem[]
}

model UserAvatarItem {
  id           Int      @id @default(autoincrement())
  userId       Int
  avatarItemId Int

  equipped     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id])
  avatarItem   AvatarItem @relation(fields: [avatarItemId], references: [id])

  @@unique([userId, avatarItemId])
}

model EventComment {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model Hobby {
  id     Int         @id @default(autoincrement())
  name   String      @unique
  users  UserHobby[]
  events Event[]
}

model UserHobby {
  id      Int @id @default(autoincrement())
  userId  Int
  hobbyId Int

  user  User  @relation(fields: [userId], references: [id])
  hobby Hobby @relation(fields: [hobbyId], references: [id])

  @@unique([userId, hobbyId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  city        String
  location    String?
  dateTime    DateTime
  capacity    Int?
  createdAt   DateTime @default(now())

  hobbyId     Int
  hobby       Hobby @relation(fields: [hobbyId], references: [id])

  createdById Int
  createdBy   User @relation("UserEventsCreated", fields: [createdById], references: [id])

  participants EventParticipant[]
  favorites    EventFavorite[]
  comments     EventComment[]
  messages     EventMessage[]

  // 🔍 ML logging: bu event'e ait view / click kayıtları
  views        EventView[]
  clicks       EventClick[]
}

model EventParticipant {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  status    String   @default("JOINED")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model EventFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model EventMessage {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model EmailLoginCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([email])
}

model Country {
  id        Int      @id
  name      String
  iso2      String?  @db.VarChar(2)
  iso3      String?  @db.VarChar(3)

  states    State[]
  cities    City[]
}

model State {
  id         Int      @id
  name       String
  countryId  Int

  country    Country  @relation(fields: [countryId], references: [id])
  cities     City[]
}

model City {
  id         Int      @id
  name       String
  countryId  Int
  stateId    Int?

  country    Country  @relation(fields: [countryId], references: [id])
  state      State?   @relation(fields: [stateId], references: [id])
}

/* 🔍 ML LOGGING TABLOLARI
   EventView: bir kullanıcının (veya anon session'ın) bir event kartını / sayfasını görmesi
   EventClick: bir event kartına tıklaması
*/

model EventView {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id])

  // Kullanıcı login değilse null kalabilir
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])

  // Opsiyonel metadata (şimdilik sadece string, ileride doldurursun)
  source    String?  // "list", "recommendation", "search" vb.
  sessionId String?
  ipHash    String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([userId])
}

model EventClick {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id])

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])

  source    String?
  sessionId String?
  ipHash    String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([userId])
}
