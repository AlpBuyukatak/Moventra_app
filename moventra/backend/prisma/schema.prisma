generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  city         String?
  createdAt    DateTime @default(now())

  hobbies        UserHobby[]
  eventsCreated  Event[]            @relation("UserEventsCreated")
  participations EventParticipant[]
  favorites      EventFavorite[]
  comments       EventComment[]
  messages       EventMessage[]
  avatar         UserAvatar?
  avatarItems    UserAvatarItem[]
}

model UserAvatar {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  gender    String?  // "male" | "female" | "other" (frontend’de enum gibi kullanırsın)
  bodyType  String?  // "slim" | "normal" | "athletic" vs.
  skinTone  String?  // "light" | "medium" | "dark" (veya hex color)
  hairColor String?  // "#ffcc99" gibi

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}
model AvatarItem {
  id        Int      @id @default(autoincrement())
  name      String
  slot      String   // "hair" | "top" | "bottom" | "shoes" | "accessory"
  // 3D model / texture dosyalarının yolları:
  modelUrl   String? // .glb / .gltf gibi
  textureUrl String? // istersen

  isDefault Boolean  @default(false) // yeni user’a otomatik verilecek mi?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedBy   UserAvatarItem[]
}

model UserAvatarItem {
  id          Int      @id @default(autoincrement())
  userId      Int
  avatarItemId Int

  equipped   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  avatarItem AvatarItem @relation(fields: [avatarItemId], references: [id])

  @@unique([userId, avatarItemId])
}


model EventComment {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model Hobby {
  id     Int         @id @default(autoincrement())
  name   String      @unique
  users  UserHobby[]
  events Event[]
}

model UserHobby {
  id      Int @id @default(autoincrement())
  userId  Int
  hobbyId Int

  user  User  @relation(fields: [userId], references: [id])
  hobby Hobby @relation(fields: [hobbyId], references: [id])

  @@unique([userId, hobbyId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  city        String
  location    String?
  dateTime    DateTime
  capacity    Int?
  createdAt   DateTime @default(now())

  hobbyId Int
  hobby   Hobby @relation(fields: [hobbyId], references: [id])

  createdById Int
  createdBy   User @relation("UserEventsCreated", fields: [createdById], references: [id])

  participants EventParticipant[]
  favorites    EventFavorite[]
  comments     EventComment[]
  messages     EventMessage[]     // ← EventMessage ile ilişki
}

model EventParticipant {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  status    String   @default("JOINED")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model EventFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model EventMessage {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

