generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int               @id @default(autoincrement())
  email          String            @unique
  passwordHash   String
  name           String
  city           String?
  createdAt      DateTime          @default(now())

  hobbies        UserHobby[]
  eventsCreated  Event[]           @relation("UserEventsCreated")
  participations EventParticipant[]
  favorites      EventFavorite[]
}

model Hobby {
  id      Int        @id @default(autoincrement())
  name    String     @unique
  users   UserHobby[]
  events  Event[]
}

model UserHobby {
  id      Int   @id @default(autoincrement())
  userId  Int
  hobbyId Int

  user  User  @relation(fields: [userId], references: [id])
  hobby Hobby @relation(fields: [hobbyId], references: [id])

  @@unique([userId, hobbyId])
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  city        String
  location    String?
  dateTime    DateTime
  capacity    Int?
  createdAt   DateTime  @default(now())

  hobbyId     Int
  hobby       Hobby     @relation(fields: [hobbyId], references: [id])

  createdById Int
  createdBy   User      @relation("UserEventsCreated", fields: [createdById], references: [id])

  participants EventParticipant[]
  favorites    EventFavorite[]
}

model EventParticipant {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  status    String   @default("JOINED")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model EventFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

